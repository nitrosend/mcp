{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "com.nitrosend/mcp",
  "title": "Nitrosend",
  "description": "Connect Claude to Nitrosend to manage contacts, compose emails, build flows, and launch campaigns",
  "version": "0.1.0",
  "websiteUrl": "https://nitrosend.com",
  "repository": {
    "url": "https://github.com/nitrosend/nitrosend",
    "source": "github",
    "id": "nitrosend/nitrosend"
  },
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@nitrosend/mcp",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "runtimeHint": "npx",
      "environmentVariables": [
        {
          "name": "NITROSEND_API_KEY",
          "description": "Your Nitrosend API key (starts with nskey_live_)",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
